
# -----------------------------
# TTY STYLE KITTY CONFIG
# -----------------------------

# Font (use basic monospace like TTY)
# font_family monospace
# bold_font auto
# italic_font auto
# bold_italic_font auto
font_size 11.0

# Transparency and dynamic opacity

# Cursor (block like real TTY)
shell_integration no-cursor
cursor_shape block
cursor_blink_interval 0
# cursor #C0C0C0

# Window padding
window_padding_width 2

# No fancy UI
enable_audio_bell no
visual_bell_duration 0
hide_window_decorations yes

# Disable ligatures
disable_ligatures always

# Scrollback (TTY-like)
scrollback_lines 1000

# Disable fancy features
confirm_os_window_close 0
remember_window_size  no
initial_window_width  80c
initial_window_height 24c

map ctrl+k scroll_line_up
map ctrl+j scroll_line_down
map ctrl+u scroll_page_up
map ctrl+d scroll_page_down


# BEGIN_KITTY_FONTS
font_family      family="JetBrainsMono Nerd Font Mono"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS
background_opacity 1.0

allow_remote_control no
shell_integration no-rc
cursor_blink_interval 0
notify_on_cmd_finish never
linux_display_server x11
# BEGIN_KITTY_THEME
# Adwaita darker
include current-theme.conf
# END_KITTY_THEME

# background #1b1612
# foreground #d4c4a8
# selection_background #3c3836
# selection_foreground #ebdbb2
#


# background / foreground
# background #18110c
# foreground #c9b79c
# cursor     #e6d5b8

# normal
# color0  #18110c
# color1  #b85651
# color2  #7c8f4e
# color3  #c18f41
# color4  #5f819d
# color5  #9a6e8a
# color6  #6d8f6f
# color7  #c9b79c

# bright
# color8  #3a2f28
# color9  #d46a5f
# color10 #9fbf60
# color11 #e0a84f
# color12 #7fa6c4
# color13 #c08cb3
# color14 #8fbf7f
# color15 #f2e5bc
