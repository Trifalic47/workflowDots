#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
(
    default_album_art_path: None,
    format_tag_separator: "  َ°„¾  ",
    browser_column_widths: [20, 45, 35],
    background_color: None,
    text_color: Some("#c0caf5"),
    header_background_color: None,
    modal_background_color: Some("#1a1b26"),
    modal_backdrop: true,
    preview_label_style: (fg: "#7aa2f7"),
    preview_metadata_group_style: (fg: "#7aa2f7", modifiers: "Bold"),
    highlighted_item_style: (fg: "#bb9af7", modifiers: "Bold"),
    current_item_style: (fg: "#1a1b26", bg: "#bb9af7", modifiers: "Bold"),
    borders_style: (fg: "#414868"),
    highlight_border_style: (fg: "#7aa2f7"),
    symbols: (
        song: "َ°ژ† ",
        dir: "َ°‰‹ ",
        playlist: "َ°²’ ",
        marker: "َ°„¬ ",
        ellipsis: "َ°‡ک",
        song_style: (fg: "#7aa2f7"),
        dir_style: (fg: "#e0af68"),
        playlist_style: (fg: "#bb9af7"),
    ),
    level_styles: (
        info: (fg: "#7aa2f7"),
        warn: (fg: "#e0af68"),
        error: (fg: "#f7768e"),
        debug: (fg: "#9ece6a"),
        trace: (fg: "#bb9af7"),
    ),
    progress_bar: (
        symbols: [" ", " ", "â–ˆ", " ", "â–ˆ"],
        track_style: (fg: "#24283b"),
        elapsed_style: (fg: "#7dcfff"),
        thumb_style: (fg: "#7dcfff"),
        use_track_when_empty: true,
    ),
    scrollbar: (
        symbols: ["â”‚", "â”ƒ", "َ°‡¼", "َ°‡½"],
        track_style: (fg: "#24283b"),
        ends_style: (fg: "#414868"),
        thumb_style: (fg: "#7dcfff"),
    ),
    tab_bar: (
        active_style: (fg: "#7dcfff", modifiers: "Bold | Underlined"),
        inactive_style: (fg: "#414868"),
    ),
    cava: (
        bars: 0,
        look: "َ±‘–",
        style: (fg: "#7dcfff"),
    ),
    lyrics: (
        timestamp: true
    ),
    browser_song_format: [
        (
            kind: Group([
                (kind: Property(Track), style: (fg: "#414868")),
                (kind: Text(" ")),
            ])
        ),
        (
            kind: Group([
                (kind: Property(Title), style: (fg: "#c0caf5", modifiers: "Bold")),
                (kind: Text("  َ°„¾  "), style: (fg: "#7aa2f7")),
                (kind: Property(Artist), style: (fg: "#7dcfff")),
            ]),
            default: (kind: Property(Filename))
        ),
    ],
    song_table_format: [
        (
            prop: (kind: Property(Title),
                default: (kind: Property(Filename))
            ),
            label_prop: (kind: Text("َ°ژ† TITLE")),
            width: "50%",
        ),
        (
            prop: (kind: Property(Artist), style: (fg: "#7dcfff"),
                default: (kind: Text("َ° ƒ UNKNOWN"))
            ),
            label_prop: (kind: Text("َ° ƒ ARTIST")),
            width: "35%",
        ),
        (
            prop: (kind: Property(Duration), style: (fg: "#7aa2f7"),
                default: (kind: Text("-"))
            ),
            label_prop: (kind: Text("َ°¥” ")),
            width: "15%",
            alignment: Right,
        ),
    ],
    layout: Split(
        direction: Vertical,
        panes: [
            (
                size: "1",
                pane: Pane(Tabs),
            ),
            (
                size: "100%",
                pane: Pane(TabContent),
            ),
            (
                size: "4",
                borders: "TOP",
                pane: Split(
                    direction: Horizontal,
                    panes: [
                        (
                            size: "25%",
                            pane: Component("player_info")
                        ),
                        (
                            size: "50%",
                            pane: Split(
                                direction: Vertical,
                                panes: [
                                    (size: "1", pane: Component("progress_bar")),
                                    (size: "1", pane: Component("controls")),
                                ]
                            )
                        ),
                        (
                            size: "25%",
                            pane: Component("volume_and_stats")
                        ),
                    ]
                )
            ),
        ],
    ),
    components: {
        "player_info": Pane(Property(
            content: [
                (kind: Text(" َ°ژ† "), style: (fg: "#bb9af7", modifiers: "Bold")),
                (kind: Property(Song(Title)), style: (fg: "#c0caf5", modifiers: "Bold"), default: (kind: Text("Idle"))),
                (kind: Transform(Replace(content: (kind: Property(Song(Filename))), replacements: [
                    (match: r".*\.mp4$", replace: (kind: Text("\n َ°گٹ VIDEO AVAILABLE "), style: (fg: "#9ece6a", modifiers: "Bold"))),
                ], use_regex: true))),
                (kind: Text("\n َ° ƒ "), style: (fg: "#7dcfff")),
                (kind: Property(Song(Artist)), style: (fg: "#7aa2f7"), default: (kind: Text("Unknown"))),
            ],
            align: Left,
        )),
        "progress_bar": Pane(ProgressBar),
        "controls": Pane(Property(
            content: [
                (kind: Property(Status(Elapsed)), style: (fg: "#7dcfff")),
                (kind: Text(" / ")),
                (kind: Property(Status(Duration)), style: (fg: "#c0caf5")),
                (kind: Text("   ")),
                (kind: Transform(Replace(content: (kind: Property(Status(StateV2()))), replacements: [
                    (match: "Playing", replace: (kind: Text("َ°گٹ"), style: (fg: "#9ece6a"))),
                    (match: "Paused", replace: (kind: Text("َ°ڈ¤"), style: (fg: "#e0af68"))),
                    (match: "Stopped", replace: (kind: Text("َ°“›"), style: (fg: "#f7768e"))),
                ]))),
                (kind: Text("   ")),
                (kind: Transform(Replace(content: (kind: Property(Status(InputMode()))), replacements: [
                    (match: "Normal", replace: (kind: Text("NORMAL"), style: (fg: "#7aa2f7"))),
                    (match: "Insert", replace: (kind: Text("INSERT"), style: (fg: "#bb9af7"))),
                    (match: "Command", replace: (kind: Text("COMMAND"), style: (fg: "#e0af68"))),
                ]))),
            ],
            align: Center,
        )),
        "volume_and_stats": Pane(Property(
            content: [
                (kind: Text(" VOL "), style: (fg: "#7aa2f7")),
                (kind: Property(Status(Volume))),
                (kind: Text("%  ")),
                (kind: Property(Status(RepeatV2(on_label: "َ°‘–", off_label: "َ°‘–", on_style: (fg: "#bb9af7"), off_style: (fg: "#414868"))))),
                (kind: Text(" ")),
                (kind: Property(Status(RandomV2(on_label: "َ°’‌", off_label: "َ°’‌", on_style: (fg: "#bb9af7"), off_style: (fg: "#414868"))))),
            ],
            align: Right,
        )),
    },
)
